{
  "manifest_version": 3,
  "name": "Solar Operator Sync",
  "short_name": "Solar Operator",
  "version": "1.4.5",
  "description": "Auto-captures Green Mountain Power and VEC billing data so Solar Operator can email NEPOOL-format quarterly solar reports.",
  "author": "Solar Operator",
  "homepage_url": "https://solaroperator.org",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "cookies"
  ],
  "host_permissions": [
    "https://*.greenmountainpower.com/*",
    "https://api.greenmountainpower.com/*",
    "https://vermontelectric.smarthub.coop/*",
    "https://*.smarthub.coop/*",
    "https://api.solaroperator.org/*",
    "https://solaroperator.org/*",
    "https://*.solaroperator.org/*",
    "https://web-production-49c83.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://greenmountainpower.com/*",
        "https://*.greenmountainpower.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://vermontelectric.smarthub.coop/*",
        "https://*.smarthub.coop/*"
      ],
      "js": [
        "vec_content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://solaroperator.org/*",
        "https://*.solaroperator.org/*",
        "https://web-production-49c83.up.railway.app/*"
      ],
      "js": [
        "so_bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Solar Operator Sync",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html"
}
